rules_version = '2';

// ============================================================================
// Reglas de seguridad — Fluss (multi-salón)
// ============================================================================
// Aviso: estas reglas cubren el modelo de datos descrito en README.md, pero
// no reemplazan una revisión de seguridad propia. Antes de producción,
// pruébenlas con el Firebase Emulator Suite (firebase emulators:start) y
// verifiquen la sintaxis contra la documentación vigente de Firestore
// Security Rules — la función get()/exists() y el acceso a
// request.auth.token.email son estables, pero conviene confirmarlo.
//
// Modelo de roles (colección /users/{uid}):
//   role: 'platform_admin' | 'local_admin' | 'basic'
//   salonId: string | null   (null solo para platform_admin)
//
// Alta de usuarios sin backend propio: se usa un patrón de "invitación"
// (colección /invites/{email}) que el propio usuario reclama la primera vez
// que inicia sesión (ver js/auth.js). No hay Cloud Functions ni Admin SDK.
//
// IMPORTANTE: las funciones auxiliares (isSignedIn, myRole, etc.) están
// declaradas DENTRO de `match /databases/{database}/documents { ... }`
// porque usan `$(database)` en sus llamadas a get()/exists() — ese path
// variable solo existe dentro de ese bloque. Declararlas afuera compila
// pero rompe get()/exists() en tiempo de ejecución (error real detectado
// con el Rules Playground: "Invalid argument provided to call. Function:
// [exists]").

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email.lower();
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? myProfile().role
        : null;
    }

    function mySalonId() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? myProfile().salonId
        : null;
    }

    function isPlatformAdmin() {
      return myRole() == 'platform_admin';
    }

    function isLocalAdminOf(salonId) {
      return myRole() == 'local_admin' && mySalonId() == salonId;
    }

    function isMemberOf(salonId) {
      return isSignedIn() && mySalonId() == salonId;
    }

    // Solo se permite crear cuenta "email verificado" para reclamar invitaciones
    // por email/password (Google ya viene con el email verificado por Google).
    function emailIsVerified() {
      return request.auth.token.email_verified == true;
    }

    // ---------- users ----------
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId())
      );

      // Alta propia SOLO si existe una invitación pendiente que coincide en
      // email, y el rol/salón que se está creando son EXACTAMENTE los de
      // esa invitación (evita que alguien se autoasigne un rol).
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && emailIsVerified()
        && exists(/databases/$(database)/documents/invites/$(myEmail()))
        && request.resource.data.role == get(/databases/$(database)/documents/invites/$(myEmail())).data.role
        && request.resource.data.salonId == get(/databases/$(database)/documents/invites/$(myEmail())).data.salonId
        && request.resource.data.email == request.auth.token.email;

      allow update: if isSignedIn() && (
        // el propio usuario puede tocar solo nombre/foto, no su rol ni salón
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.salonId == resource.data.salonId) ||
        isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId()
          && request.resource.data.salonId == mySalonId())
      );

      allow delete: if isPlatformAdmin() || (myRole() == 'local_admin' && resource.data.salonId == mySalonId());
    }

    // ---------- invites ----------
    // Doc id = email en minúsculas.
    match /invites/{email} {
      allow read: if isSignedIn() && (myEmail() == email || isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId()));

      allow create: if isSignedIn() && (
        isPlatformAdmin() ||
        (myRole() == 'local_admin'
          && request.resource.data.role == 'basic'
          && request.resource.data.salonId == mySalonId())
      );

      // El propio invitado la borra al reclamarla; los admins pueden cancelarla.
      allow delete: if isSignedIn() && (myEmail() == email || isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId()));
    }

    // ---------- salons ----------
    match /salons/{salonId} {
      allow read: if isMemberOf(salonId) || isPlatformAdmin();
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || isLocalAdminOf(salonId);
      allow delete: if isPlatformAdmin();

      // ---------- categories ----------
      match /categories/{categoryId} {
        allow read: if isMemberOf(salonId) || isPlatformAdmin();
        allow write: if isLocalAdminOf(salonId) || isPlatformAdmin();
      }

      // ---------- products ----------
      match /products/{productId} {
        allow read: if isMemberOf(salonId) || isPlatformAdmin();
        allow write: if isLocalAdminOf(salonId) || isPlatformAdmin();
      }

      // ---------- orders ----------
      match /orders/{orderId} {
        allow read: if isMemberOf(salonId) || isPlatformAdmin();
        // Solo el admin local define fechas, abre y cierra el pedido.
        allow write: if isLocalAdminOf(salonId) || isPlatformAdmin();

        // ---------- order items (uno por usuario+producto, id = `${uid}_${productId}`) ----------
        match /items/{itemId} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();

          allow create, update: if (
            (isMemberOf(salonId)
              && request.resource.data.userId == request.auth.uid
              && get(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)).data.status == 'draft'
              && !exists(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)/submissions/$(request.auth.uid)))
            || isLocalAdminOf(salonId)
            || isPlatformAdmin()
          );

          allow delete: if (
            (isMemberOf(salonId)
              && resource.data.userId == request.auth.uid
              && get(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)).data.status == 'draft'
              && !exists(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)/submissions/$(request.auth.uid)))
            || isLocalAdminOf(salonId)
            || isPlatformAdmin()
          );
        }

        // ---------- ajustes finales del admin, por producto ----------
        match /adjustments/{productId} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();
          allow write: if isLocalAdminOf(salonId) || isPlatformAdmin();
        }

        // ---------- recepción: cantidad que realmente llegó, por producto ----------
        match /received/{productId} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();
          allow write: if isLocalAdminOf(salonId) || isPlatformAdmin();
        }

        // ---------- cierre individual: cada usuario marca su propio pedido
        // como "listo" (bloquea sus items) antes de que cierre todo el
        // período. Doc id = uid. Solo existe si esa persona ya cerró.
        match /submissions/{uid} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();

          allow create, update, delete: if (
            (isMemberOf(salonId)
              && request.auth.uid == uid
              && get(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)).data.status == 'draft')
            || isLocalAdminOf(salonId)
            || isPlatformAdmin()
          );
        }
      }
    }
  }
}
