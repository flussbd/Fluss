rules_version = '2';

// ============================================================================
// Reglas de seguridad — Fluss (multi-salón)
// ============================================================================
// Aviso: estas reglas cubren el modelo de datos descrito en README.md, pero
// no reemplazan una revisión de seguridad propia. Antes de producción,
// pruébenlas con el Firebase Emulator Suite (firebase emulators:start) y
// verifiquen la sintaxis contra la documentación vigente de Firestore
// Security Rules — la función get()/exists() y el acceso a
// request.auth.token.email son estables, pero conviene confirmarlo.
//
// Modelo de roles (colección /users/{uid}):
//   role: 'platform_admin' | 'local_admin' | 'basic'
//   salonId: string | null   (null solo para platform_admin)
//   status: 'active' | 'blocked' | 'inactive'   (default 'active' si falta)
//     'blocked' = bloqueo reversible por su admin local (solo usuarios básicos).
//     'inactive' = "dado de baja" por el admin de plataforma (solo admins locales).
//     Cualquiera de los dos anula el rol/salón para TODAS las reglas.
//
// Colección /salons/{salonId}:
//   active: boolean   (default true si falta) — false = el admin de
//     plataforma dio de baja el salón: nadie puede seguir escribiendo ahí
//     (catálogo, pedidos), pero la lectura del historial sigue andando.
//
// Alta de usuarios sin backend propio: se usa un patrón de "invitación"
// (colección /invites/{email}) que el propio usuario reclama la primera vez
// que inicia sesión (ver js/auth.js). No hay Cloud Functions ni Admin SDK.
//
// IMPORTANTE: las funciones auxiliares (isSignedIn, myRole, etc.) están
// declaradas DENTRO de `match /databases/{database}/documents { ... }`
// porque usan `$(database)` en sus llamadas a get()/exists() — ese path
// variable solo existe dentro de ese bloque. Declararlas afuera compila
// pero rompe get()/exists() en tiempo de ejecución (error real detectado
// con el Rules Playground: "Invalid argument provided to call. Function:
// [exists]").

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email.lower();
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Un usuario 'blocked' (bloqueado por su admin local, reversible) o
    // 'inactive' (dado de baja) pierde el rol/salón para TODAS las reglas
    // — lectura y escritura — como si no tuviera perfil: bloqueo real, no
    // solo cosmético. Default 'active' si el campo no existe (perfiles viejos).
    function myStatusIsActive() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myProfile().get('status', 'active') == 'active';
    }

    function myRole() {
      return myStatusIsActive() ? myProfile().role : null;
    }

    function mySalonId() {
      return myStatusIsActive() ? myProfile().salonId : null;
    }

    // Un salón dado de baja por el admin de plataforma (salons/{salonId}.active
    // == false) no puede seguir "operando": nadie puede escribir catálogo,
    // pedidos, etc. A propósito NO se usa para bloquear LECTURA (isMemberOf
    // sigue sin depender de esto) — el equipo de ese salón debe poder seguir
    // viendo su historial aunque el salón esté inactivo.
    //
    // Importante: si el doc salons/{salonId} no existe (nunca debería pasar
    // en la app real, porque createSalon() siempre lo crea, pero SÍ pasa en
    // varios tests que escriben directo en subcolecciones sin crear antes el
    // doc padre) se trata como salón ACTIVO por defecto — el default es
    // "true" salvo que exista el doc y diga explícitamente active:false.
    function salonIsActive(salonId) {
      return !exists(/databases/$(database)/documents/salons/$(salonId))
        || get(/databases/$(database)/documents/salons/$(salonId)).data.get('active', true) == true;
    }

    function isPlatformAdmin() {
      return myRole() == 'platform_admin';
    }

    function isLocalAdminOf(salonId) {
      return myRole() == 'local_admin' && mySalonId() == salonId;
    }

    function isMemberOf(salonId) {
      return isSignedIn() && mySalonId() == salonId;
    }

    // Solo se permite crear cuenta "email verificado" para reclamar invitaciones
    // por email/password (Google ya viene con el email verificado por Google).
    function emailIsVerified() {
      return request.auth.token.email_verified == true;
    }

    // Los campos de recepción (receivedQuantity/receivedUnitPrice/etc.) viven
    // en el mismo doc que el propio pedido de cada persona (items/{itemId}),
    // pero solo el admin los puede tocar — un usuario básico editando su
    // propio pedido (mientras está en draft) no debe poder tocarlos.
    // resource == null → estamos creando el doc (todavía no puede tener
    // ninguno de estos campos); si no, comparamos qué campos cambiaron.
    function receivedFieldsUntouched() {
      return resource == null
        ? !('receivedQuantity' in request.resource.data)
          && !('receivedUnitPrice' in request.resource.data)
          && !('receivedUpdatedBy' in request.resource.data)
          && !('receivedUpdatedAt' in request.resource.data)
        : !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['receivedQuantity', 'receivedUnitPrice', 'receivedUpdatedBy', 'receivedUpdatedAt']);
    }

    // Mismo patrón que receivedFieldsUntouched(), para el campo "active" de
    // un salón: un admin local puede editar SU salón (ej. el nombre), pero
    // nunca ese campo puntual.
    function salonActiveFieldUntouched() {
      return resource == null
        ? !('active' in request.resource.data)
        : !request.resource.data.diff(resource.data).affectedKeys().hasAny(['active']);
    }

    // ---------- users ----------
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId())
      );

      // Alta propia SOLO si existe una invitación pendiente que coincide en
      // email, y el rol/salón que se está creando son EXACTAMENTE los de
      // esa invitación (evita que alguien se autoasigne un rol).
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && emailIsVerified()
        && exists(/databases/$(database)/documents/invites/$(myEmail()))
        && request.resource.data.role == get(/databases/$(database)/documents/invites/$(myEmail())).data.role
        && request.resource.data.salonId == get(/databases/$(database)/documents/invites/$(myEmail())).data.salonId
        && request.resource.data.email == request.auth.token.email;

      allow update: if isSignedIn() && (
        // el propio usuario puede tocar solo nombre/foto, no su rol ni salón
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.salonId == resource.data.salonId) ||
        isPlatformAdmin() ||
        // el admin local solo puede tocar (incluye bloquear/dar de baja vía
        // el campo status) usuarios BÁSICOS de su propio salón, y no les
        // puede cambiar el rol ni el salón por esta vía — eso evita que
        // alguien se autopromocione o mande a otro salón sin pasar por el
        // sistema de invitaciones.
        (myRole() == 'local_admin'
          && resource.data.role == 'basic'
          && resource.data.salonId == mySalonId()
          && request.resource.data.role == 'basic'
          && request.resource.data.salonId == mySalonId())
      );

      allow delete: if isPlatformAdmin()
        || (myRole() == 'local_admin' && resource.data.role == 'basic' && resource.data.salonId == mySalonId());
    }

    // ---------- invites ----------
    // Doc id = email en minúsculas.
    match /invites/{email} {
      allow read: if isSignedIn() && (myEmail() == email || isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId()));

      allow create: if isSignedIn() && (
        isPlatformAdmin() ||
        (myRole() == 'local_admin'
          && request.resource.data.role == 'basic'
          && request.resource.data.salonId == mySalonId())
      );

      // El propio invitado la borra al reclamarla; los admins pueden cancelarla.
      allow delete: if isSignedIn() && (myEmail() == email || isPlatformAdmin() ||
        (myRole() == 'local_admin' && resource.data.salonId == mySalonId()));
    }

    // ---------- salons ----------
    match /salons/{salonId} {
      allow read: if isMemberOf(salonId) || isPlatformAdmin();
      allow create: if isPlatformAdmin();
      // Solo el admin de plataforma puede dar de baja/reactivar un salón
      // (campo "active"): un admin local no debe poder auto-desactivar su
      // propio salón, aunque sí pueda editar otros campos (ej. el nombre).
      allow update: if isPlatformAdmin() || (isLocalAdminOf(salonId) && salonActiveFieldUntouched());
      allow delete: if isPlatformAdmin();

      // ---------- categories ----------
      match /categories/{categoryId} {
        allow read: if isMemberOf(salonId) || isPlatformAdmin();
        allow write: if (isLocalAdminOf(salonId) && salonIsActive(salonId)) || isPlatformAdmin();
      }

      // ---------- products ----------
      match /products/{productId} {
        allow read: if isMemberOf(salonId) || isPlatformAdmin();
        allow write: if (isLocalAdminOf(salonId) && salonIsActive(salonId)) || isPlatformAdmin();
      }

      // ---------- orders ----------
      match /orders/{orderId} {
        allow read: if isMemberOf(salonId) || isPlatformAdmin();
        // Solo el admin local define fechas, abre y cierra el pedido.
        allow write: if (isLocalAdminOf(salonId) && salonIsActive(salonId)) || isPlatformAdmin();

        // ---------- order items (uno por usuario+producto, id = `${uid}_${productId}`) ----------
        // Los mismos docs también guardan, más adelante, cuánto le llegó a
        // esa persona de ese producto (receivedQuantity/receivedUnitPrice,
        // cargado por el admin — ver setItemReceivedQuantity en db.js). No
        // hace falta una regla aparte: la de abajo ya cubre "el admin puede
        // escribir este doc en cualquier momento", sea para el pedido o para
        // la recepción.
        match /items/{itemId} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();

          allow create, update: if (
            (isMemberOf(salonId)
              && salonIsActive(salonId)
              && request.resource.data.userId == request.auth.uid
              && get(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)).data.status == 'draft'
              && !exists(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)/submissions/$(request.auth.uid))
              && receivedFieldsUntouched())
            || (isLocalAdminOf(salonId) && salonIsActive(salonId))
            || isPlatformAdmin()
          );

          allow delete: if (
            (isMemberOf(salonId)
              && salonIsActive(salonId)
              && resource.data.userId == request.auth.uid
              && get(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)).data.status == 'draft'
              && !exists(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)/submissions/$(request.auth.uid)))
            || (isLocalAdminOf(salonId) && salonIsActive(salonId))
            || isPlatformAdmin()
          );
        }

        // ---------- ajustes finales del admin, por producto ----------
        match /adjustments/{productId} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();
          allow write: if (isLocalAdminOf(salonId) && salonIsActive(salonId)) || isPlatformAdmin();
        }

        // ---------- cierre individual: cada usuario marca su propio pedido
        // como "listo" (bloquea sus items) antes de que cierre todo el
        // período. Doc id = uid. Solo existe si esa persona ya cerró.
        match /submissions/{uid} {
          allow read: if isMemberOf(salonId) || isPlatformAdmin();

          allow create, update, delete: if (
            (isMemberOf(salonId)
              && salonIsActive(salonId)
              && request.auth.uid == uid
              && get(/databases/$(database)/documents/salons/$(salonId)/orders/$(orderId)).data.status == 'draft')
            || (isLocalAdminOf(salonId) && salonIsActive(salonId))
            || isPlatformAdmin()
          );
        }
      }
    }
  }
}
